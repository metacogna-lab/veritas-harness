# Veritas environment template — copy to .env and fill values.
# Never commit real secrets. See PROVIDER.md / src/config/README.md per harness.
# Sync with: python ~/scripts/confirm_env.py --sync

# --- Provider API keys (set only those you use) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
CODEX_API_KEY=
OPENROUTER_API_KEY=

# --- Harness provider / model (optional overrides) ---
HARNESS_PROVIDER=
HARNESS_MODEL=
HARNESS_CONFIG=

# --- Veritas paths & app ---
VERITAS_HARNESS=
VERITAS_RUNS_DIR=
VERITAS_MISSIONS_DIR=
VERITAS_MODEL=

# --- HTTP control plane / jobs (veritas-example serve) ---
PORT=
DATABASE_URL=
RUN_WORKER=

# --- Telemetry ---
LOG_FILE=
LOG_STDOUT=

# --- Sandbox providers (Phase 3.0) ---
SANDBOX_PROVIDER=
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=
